# ── PostgreSQL ──────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecommerce
DB_USER=postgres
DB_PASSWORD=your_password

# 커넥션 풀 크기
DB_POOL_MIN=1
DB_POOL_MAX=10

# ── S3 / MinIO ──────────────────────────────
S3_BUCKET_NAME=spoffy-images

# 이미지 공개 URL prefix
# AWS S3:   https://your-bucket.s3.ap-northeast-2.amazonaws.com
# CloudFront: https://xxxx.cloudfront.net
# MinIO 로컬: http://localhost:9000/spoffy-images
S3_PUBLIC_URL=http://localhost:9000/spoffy-images

S3_REGION=ap-northeast-2

# MinIO 로컬 전용 — EKS 배포 시 아래 세 항목 제거 (IAM Role 자동 사용)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
